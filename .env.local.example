# ─────────────────────────────────────────────────────────────────────────────
# Aurum — environment variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored; this file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API

# Project URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose to the browser; RLS is your data boundary
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — bypasses RLS; server-side only, never in the browser bundle
# Used by: API routes (plaid sync, settings disconnect, delete account) and seed script
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── Plaid ─────────────────────────────────────────────────────────────────────
# Plaid dashboard → Team Settings → Keys
# https://dashboard.plaid.com/team/keys

# Your Plaid client ID (not secret — but keep it server-side anyway)
PLAID_CLIENT_ID=your_client_id_here

# Sandbox secret key — use the "Sandbox" secret, not Development or Production
PLAID_SECRET=your_sandbox_secret_here

# Environment tier — keep as "sandbox" for local development
# Change to "development" or "production" only with the matching secret and Plaid approval
PLAID_ENV=sandbox


# ── Google Gemini ─────────────────────────────────────────────────────────────
# Google AI Studio → Get API key
# https://aistudio.google.com/app/apikey
# Server-side only — never referenced in client components

GEMINI_API_KEY=AIzaSy...
